# Groq API (OpenAI-compatible base: https://api.groq.com/openai/v1)
GROQ_API_KEY=your_groq_api_key_here

# Llama model for prompt optimization (default: small / fast)
GROQ_OPTIMIZER_MODEL=llama-3.1-8b-instant

# Prompts with fewer than this many tokens skip the rewriter LLM (faster). Set 0 to always rewrite.
# GROQ_OPTIMIZER_SKIP_BELOW_TOKENS=16

# Optional override for the chat completions base URL
# GROQ_OPENAI_BASE=https://api.groq.com/openai/v1

# Set to 1 to print analytics events to stderr (default: silent)
# OPENROUTER_ANALYTICS_LOG=1

# Router cost estimates (USD per 1K tokens) — optional tuning
# LLAMA3_8B_INPUT_COST=0.00005
# LLAMA3_8B_OUTPUT_COST=0.00008
# MIXTRAL_8X7B_INPUT_COST=0.00011
# MIXTRAL_8X7B_OUTPUT_COST=0.00034
# LLAMA3_70B_INPUT_COST=0.00059
# LLAMA3_70B_OUTPUT_COST=0.00079
